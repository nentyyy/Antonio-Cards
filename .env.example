# Telegram
BOT_TOKEN=your_single_bot_token
ADMIN_BOT_TOKEN=
ADMIN_IDS=111111111,222222222

# Database
POSTGRES_DB=cards_arena
POSTGRES_USER=cards_user
POSTGRES_PASSWORD=cards_pass
DATABASE_URL=sqlite+aiosqlite:///./cards_arena_test.db

# Logging
LOG_LEVEL=INFO

# Cooldowns
BRAWL_COOLDOWN_SECONDS=14400
BONUS_COOLDOWN_SECONDS=43200
DICE_COOLDOWN_SECONDS=3600

# Bonus rewards
BONUS_REWARD_COINS=150
BONUS_REWARD_STARS=1

# Comma-separated list of channels/usernames/chat ids for bonus tasks
CHANNEL_TASKS=@your_channel,-1001234567890

# Bonus task links shown in the bot
BONUS_CHAT_URL=https://t.me/your_chat
BONUS_SUBSCRIBE_URL=https://t.me/your_channel
BONUS_NEWS_URL=https://t.me/your_news_post
BONUS_INVITE_URL=https://t.me/your_bot?start=ref_123
BONUS_PARTNER_URL=https://t.me/your_partner
